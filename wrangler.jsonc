{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kaviya-portfolio",
  "compatibility_date": "2024-11-01",
  // Static-assets-only Worker (no `main` script): serve the built SPA from ./dist.
  // `single-page-application` returns index.html (200) for any non-asset path so
  // React Router handles the route; real assets keep their correct MIME types.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
